entry_bmr_h.pack(pady=5)

tk.Label(page_bmr,text="年齡",bg="honeydew").pack()
entry_bmr_age= tk.Entry(page_bmr,textvariable=sharded_age)
entry_bmr_age.pack(pady=5)

tk.Button(page_bmr,text="計算BMR並儲存",command=cal_bmr).pack(pady=5)
############################################

tk.Label(page_tdee,text="TDEE測量區",bg="lightyellow",font=("Arial",12)).pack(pady=10)
tk.Label(page_tdee,text="選擇運動量",bg="lightyellow").pack()
combo_gender_tdee=ttk.Combobox(page_tdee,values=["男","女"],textvariable=sharded_gender,state="readonly")
combo_gender_tdee.current(0)
combo_gender_tdee.pack(pady=5)

tk.Label(page_tdee,text="體重(kg)",bg="lightyellow").pack(pady=10)
entry_tdee_w= tk.Entry(page_tdee,textvariable=sharded_weight)
entry_tdee_w.pack(pady=5)

tk.Label(page_tdee,text="身高(cm)",bg="lightyellow").pack()
entry_tdee_h=tk.Entry(page_tdee,textvariable=sharded_height)
entry_tdee_h.pack(pady=5)

tk.Label(page_tdee,text="年齡",bg="lightyellow").pack()
entry_tdee_age= tk.Entry(page_tdee,textvariable=sharded_age)
entry_tdee_age.pack(pady=5)

tk.Label(page_tdee,text="活動量",bg="lightyellow").pack()
activity_options=["久坐 (1.2) - 辦公室工作、無運動",
    "輕度 (1.375) - 每週運動 1-3 天",
    "中度 (1.55) - 每週運動 3-5 天",
    "高度 (1.725) - 每週運動 6-7 天",
    "強度 (1.9) - 勞力工作、專業運動員"]
combo_activity= ttk.Combobox(page_tdee,values=activity_options,state="readonly",width=30)
combo_activity.current(0)
combo_activity.pack(pady=5)
tk.Button(page_tdee,text="計算TDEE並存檔",command=on_calculate_tdee).pack(pady=20)




window.mainloop()
